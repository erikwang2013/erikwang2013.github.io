n class=\"line\">class PayListErik implements PayTypeErik</span><br><span class=\"line\">&#123;</span><br><span class=\"line\">    private $observers &#x3D; [];</span><br><span class=\"line\"></span><br><span class=\"line\">    public function load()</span><br><span class=\"line\">    &#123;</span><br><span class=\"line\">        return new PayListErik();</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">    public function addCustomerErik($method, $name)</span><br><span class=\"line\">    &#123;</span><br><span class=\"line\">        if (empty($method)) &#123;     </span><br><span class=\"line\">            return false;</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        foreach ($this-&gt;observers as $obs) &#123;</span><br><span class=\"line\">            $obs-&gt;$method($this, $name);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">    public function addObserverErik($observer)</span><br><span class=\"line\">    &#123;</span><br><span class=\"line\">        $this-&gt;observers[] &#x3D; $observer;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"></span><br><span class=\"line\">&#x2F;**  日志记录</span><br><span class=\"line\"> * Class PayListLoggerErik</span><br><span class=\"line\"> *&#x2F;</span><br><span class=\"line\">class PayListLoggerErik implements PayLoggerErik</span><br><span class=\"line\">&#123;</span><br><span class=\"line\">    public function load()</span><br><span class=\"line\">    &#123;</span><br><span class=\"line\">        return new PayListLoggerErik();</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">    public function onChangeErik($sender, $args)</span><br><span class=\"line\">    &#123;</span><br><span class=\"line\">        echo &quot;